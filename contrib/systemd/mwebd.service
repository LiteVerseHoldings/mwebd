[Unit]
Description=MWEB Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/data/mwebd-data
ExecStart=/data/mwebd-build/mwebd -c mainnet -d /data/mwebd-data -l 127.0.0.1:12345 -http 127.0.0.1:12346
Restart=always
RestartSec=5
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

[Install]
WantedBy=multi-user.target
